{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@natalia/tui",
  "version": "0.0.0-m6",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npx bun run src/main.tsx",
    "format": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "npx bun test --timeout 60000",
    "smoke:ime": "npx bun run bin/ime-smoke.ts",
    "smoke:pty": "npx bun run bin/pty-smoke.ts",
    "smoke:snapshot": "npx bun run bin/screen-snapshot.ts"
  },
  "dependencies": {
    "@opentui/core": "0.4.3",
    "@opentui/keymap": "0.4.3",
    "@opentui/solid": "0.4.3",
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.13",
    "prettier": "3.6.2",
    "typescript": "5.8.2"
  }
}
