{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@natalia/agent": ["packages/agent/src/index.ts"],
      "@natalia/config": ["packages/config/src/index.ts"],
      "@natalia/contracts": ["packages/contracts/src/index.ts"],
      "@natalia/mcp": ["packages/mcp/src/index.ts"],
      "@natalia/plugin": ["packages/plugin/src/index.ts"],
      "@natalia/session": ["packages/session/src/index.ts"],
      "@natalia/tools": ["packages/tools/src/index.ts"]
    },
    "noUncheckedIndexedAccess": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "types": ["bun"]
  }
}
